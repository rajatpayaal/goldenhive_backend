{
  "collection": "package_activity_mappings",
  "validator": {
    "$jsonSchema": {
      "bsonType": "object",
      "required": ["packageId", "activityId", "discountedPrice", "isIncluded", "createdAt", "updatedAt"],
      "properties": {
        "packageId": { "bsonType": "string" },
        "activityId": { "bsonType": "string" },
        "discountedPrice": { "bsonType": ["double", "int", "long", "decimal"], "minimum": 0 },
        "isIncluded": { "bsonType": "bool" },
        "createdAt": { "bsonType": "date" },
        "updatedAt": { "bsonType": "date" }
      }
    }
  }
}
