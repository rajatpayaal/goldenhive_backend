{
  "collection": "bookings",
  "validator": {
    "$jsonSchema": {
      "bsonType": "object",
      "required": ["userId", "cartId", "packageId", "selectedActivities", "totalPrice", "travelDate", "travelers", "status", "createdAt", "updatedAt"],
      "properties": {
        "userId": { "bsonType": "string" },
        "cartId": { "bsonType": "string" },
        "packageId": { "bsonType": "string" },
        "selectedActivities": {
          "bsonType": "array",
          "items": {
            "bsonType": "object",
            "required": ["activityId"],
            "properties": {
              "activityId": { "bsonType": "string" },
              "activityName": { "bsonType": "string" },
              "price": { "bsonType": ["double", "int", "long", "decimal"], "minimum": 0 },
              "discountedPrice": { "bsonType": ["double", "int", "long", "decimal"], "minimum": 0 }
            }
          }
        },
        "totalPrice": { "bsonType": ["double", "int", "long", "decimal"], "minimum": 0 },
        "travelDate": { "bsonType": "date" },
        "travelers": { "bsonType": "int", "minimum": 1 },
        "status": { "enum": ["REQUESTED", "CONTACTED", "NEGOTIATING", "APPROVED", "REJECTED", "CLOSED"] },
        "notes": { "bsonType": "array", "items": { "bsonType": "string" } },
        "createdAt": { "bsonType": "date" },
        "updatedAt": { "bsonType": "date" },
        "followUpDate": { "bsonType": "date" }
      }
    }
  }
}
